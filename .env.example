VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets used by netlify/edge-functions/*.ts — do NOT prefix
# these with VITE_, or Vite will bundle them into the public client JS.
# Set these in the Netlify dashboard (Site configuration > Environment
# variables), not just in this local file — Netlify Edge Functions read
# them from the deploy environment, not from this .env at build time.
GROQ_API_KEY=your-groq-api-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
