{
  "name": "ielts-ai-checker",
  "private": true,
  "version": "0.0.0",
  "description": "AI-powered IELTS Writing & Speaking practice with instant band-score feedback",
  "author": "IELTS AI Checker",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "groq-sdk": "^1.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "sharp": "^0.35.3",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.ieltsai.checker",
    "productName": "IELTS AI Checker",
    "files": [
      "electron-main.cjs"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
